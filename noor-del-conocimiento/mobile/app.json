{
  "expo": {
    "name": "Noor del Conocimiento",
    "slug": "noor-del-conocimiento",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "noor",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "backgroundColor": "#f3ead4",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d2922"
    },
    "androidStatusBar": {
      "barStyle": "light-content",
      "backgroundColor": "#0d4a36"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.noordelconocimiento.app"
    },
    "android": {
      "package": "com.noordelconocimiento.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d2922"
      },
      "permissions": [],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_CONTACTS"
      ],
      "usesCleartextTraffic": false
    },
    "web": {
      "bundler": "metro",
      "output": "server",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#0d2922"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
